# ══════════════════════════════════════════════════════════════════════
logs/
*.log
*.log.*

# ══════════════════════════════════════════════════════════════════════
# DEPLOYMENT & CI CACHES
# ══════════════════════════════════════════════════════════════════════
.vercel/
.netlify/

# ══════════════════════════════════════════════════════════════════════
# BUILD / CACHE ARTIFACTS
# ══════════════════════════════════════════════════════════════════════
dist/
.cache/
tmp/
temp/
.eslintcache
.stylelintcache
.parcelcache/
.rollup.cache/

# ── User-generated uploads (local dev only) ────────────────────────────
public/uploads/
public/temp/

# ── Sentry ────────────────────────────────────────────────────────────
.sentryclirc

# ── Storybook ────────────────────────────────────────────────────────
storybook-static/

# ══════════════════════════════════════════════════════════════════════
# FILES INTENTIONALLY TRACKED (do NOT add these above)
# ══════════════════════════════════════════════════════════════════════
# ✅ package.json               — project manifest
# ✅ package-lock.json          — reproducible installs
# ✅ tsconfig.json              — TypeScript config
# ✅ vercel.json                — deployment config
# ✅ components.json            — shadcn/ui config
# ✅ next.config.ts             — Next.js config
# ✅ prisma/schema.prisma       — database schema
# ✅ prisma/seed.ts             — seed script
# ✅ prisma/migrations/         — database migrations
# ✅ supabase/migrations/*.sql  — Supabase SQL migrations
# ✅ src/content/universe/map.json — universe map data
# ✅ .github/                   — CI/CD workflows
# ✅ .husky/                    — Git hooks
# ✅ .env.local.example         — safe env template
# ═══════════════════════════════════════════════════════════════════
# DOCUMENTATION EXCLUSIONS
# ═══════════════════════════════════════════════════════════════════
docs/
docs/**
# ✅ README.md                  — project readme