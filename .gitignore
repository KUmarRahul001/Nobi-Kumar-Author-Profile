# TESTING & COVERAGE
# ══════════════════════════════════════════════════════════════════════
coverage/
.nyc_output/
*.lcov
junit.xml
test-results/
playwright-report/
playwright/.cache/
.vitest/
__snapshots__/

# ══════════════════════════════════════════════════════════════════════
