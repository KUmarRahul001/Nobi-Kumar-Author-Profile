datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Book {
  slug             String   @id
  title            String
  subtitle         String?
  seriesName       String?
  volumeNumber     Int?
  genre            String
  tags             String   // comma-separated
  shortDescription String
  fullSynopsis     String
  releaseDate      String
  isbn             String?
  language         String   @default("English")
  pages            Int?
  readingTime      String?
  status           String   @default("published")
  coverUrl         String?
  bannerUrl        String?
  trailerLink      String?
  samplePdfUrl     String?
  previewUrl       String?
  awards           String?  // comma-separated
  isFeatured       Boolean  @default(false)
  isBestseller     Boolean  @default(false)
  isEditorsChoice  Boolean  @default(false)
  displayOrder     Int      @default(0)
  seoTitle         String?
  seoDescription   String?
  socialShareImage String?
  authorNotes      String?
  ageRating        String?
  contentWarning   String?
  lastUpdated      DateTime @default(now()) @updatedAt

  // Purchase & Audio Streaming links
  amazonLink          String?
  googlePlayLink      String?
  appleBooksLink      String?
  koboLink            String?
  paperbackLink       String?
  hardcoverLink       String?
  officialWebsiteLink String?
  customLink          String?

  // Audiobook & Audio Drama Platforms
  pocketFmLink        String?
  kukuFmLink          String?
  audibleLink         String?
  storytelLink        String?

  comments            Comment[]

  createdAt DateTime @default(now())

  @@index([status])
  @@index([genre])
  @@index([isFeatured])
  @@index([displayOrder])
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  status    String   @default("active") // active | unsubscribed
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  createdAt DateTime @default(now())
  read      Boolean  @default(false)
}

// User Authentication & Roles Model (Admin & User accounts)
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  passwordHash  String?
  role          String    @default("user") // "admin" | "author" | "user"
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  comments      Comment[]

  @@index([email])
  @@index([role])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime
  createdAt    DateTime @default(now())
}

model Comment {
  id        String   @id @default(cuid())
  body      String
  status    String   @default("approved") // "pending" | "approved" | "rejected"
  postId    String?  // References blog post slug or ID
  post      Post?    @relation(fields: [postId], references: [slug], onDelete: Cascade)
  bookSlug  String?  // Optional reference to Book model
  book      Book?    @relation(fields: [bookSlug], references: [slug], onDelete: Cascade)

  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  authorName  String?
  authorEmail String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([postId])
  @@index([bookSlug])
}

model Post {
  slug           String    @id
  title          String
  excerpt        String
  content        String    // Markdown / Rich text body
  category       String    @default("Chronicles")
  tags           String    // comma-separated tags
  coverUrl       String?
  status         String    @default("published") // "draft" | "published"
  publishedAt    DateTime? @default(now())
  readingTime    String?
  authorName     String    @default("Nobi Kumar")
  seoTitle       String?
  seoDescription String?
  comments       Comment[]

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status])
  @@index([category])
  @@index([publishedAt])
}
